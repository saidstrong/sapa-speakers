# Supabase public client values. Required for auth and public form submissions.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only key for later admin/server tasks. Do not expose this in client code.
SUPABASE_SERVICE_ROLE_KEY=

# Configure the same URL in Supabase Auth site URL/redirect settings for local auth testing.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Add both local and production reset URLs to Supabase Auth redirect URLs:
# http://localhost:3000/reset-password
# https://sapa-speakers.vercel.app/reset-password
